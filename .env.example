# Desk Ai — environment template (no real secrets)
# Copy to `.env` for local builds. Netlify: set the same keys in Site settings → Environment variables.
#
# Vite exposes every `VITE_*` variable to the browser bundle.
# Only put PUBLIC values here (URLs). Never put Dodo secret API keys, Stripe secret keys,
# database passwords, or webhook signing secrets in VITE_* variables.

# Dodo Payments public license API host (no secret key required for activate/validate)
# Test:  https://test.dodopayments.com
# Live:  https://live.dodopayments.com
VITE_DODO_API_BASE=https://test.dodopayments.com

# Marketing site URL (shown on “Buy Desk Ai” links inside the app)
VITE_MARKETING_URL=https://desk-ai.com

# Deployed PWA URL (optional; for docs / marketing config alignment)
VITE_APP_URL=https://app.desk-ai.com

# IMPORTANT — Dodo dashboard secrets (API key, webhook secret) stay in Dodo / Netlify
# Functions only if you add a server later. They must NEVER be prefixed with VITE_.
